{
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/harmony-hub run build",
  "outputDirectory": "artifacts/harmony-hub/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "functions": {
    "api/index.ts": { "maxDuration": 30 }
  },
  "env": {
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
